# WorldEvolver Backend — Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT Secret (change in production!)
JWT_SECRET=worldevolver-secret-change-me-in-production

# Admin password (for author dashboard login)
ADMIN_PASSWORD=admin-change-me

# ============================================================
# AI Providers — router tries in order, first available wins
# ============================================================

# DeepSeek (primary, recommended)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama (local, optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Custom AI Provider 1 (optional)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# Custom AI Provider 2 (optional)
CUSTOM2_API_KEY=
CUSTOM2_BASE_URL=
CUSTOM2_MODEL=

# ============================================================
# AI Generation Settings
# ============================================================
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.8

# How many days of player history to include in world state reconstruction
WORLD_STATE_DAYS=7
